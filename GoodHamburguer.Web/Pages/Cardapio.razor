@page "/cardapio"
@using GoodHamburguer.Web.Models
@using GoodHamburguer.Web.Services
@inject ICardapioService CardapioService

<PageTitle>Cardápio — GoodHamburguer</PageTitle>

<div class="cardapio-header">
    <h2>🍔 Nosso Cardápio</h2>
    <p>Escolha seus itens favoritos e monte seu pedido!</p>
</div>

@if (carregando)
{
    <div class="loading-container">
        <div class="spinner"></div>
        <p>Carregando cardápio...</p>
    </div>
}
else if (erro is not null)
{
    <div class="alerta-erro">
        <span>⚠️</span> @erro
    </div>
}
else
{
    <div class="categoria-secao">
        <h4 class="categoria-titulo">🥪 Sanduíches</h4>
        <div class="cards-grid">
            @foreach (var item in cardapio.Sanduiches)
            {
                <div class="card-produto">
                    <div class="card-icone">🍔</div>
                    <div class="card-info">
                        <span class="card-nome">@item.Nome</span>
                        <span class="card-preco">R$ @item.Preco.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="categoria-secao">
        <h4 class="categoria-titulo">🍟 Acompanhamentos</h4>
        <div class="cards-grid">
            @foreach (var item in cardapio.Acompanhamentos)
            {
                <div class="card-produto">
                    <div class="card-icone">🍟</div>
                    <div class="card-info">
                        <span class="card-nome">@item.Nome</span>
                        <span class="card-preco">R$ @item.Preco.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="categoria-secao">
        <h4 class="categoria-titulo">🥤 Bebidas</h4>
        <div class="cards-grid">
            @foreach (var item in cardapio.Bebidas)
            {
                <div class="card-produto">
                    <div class="card-icone">🥤</div>
                    <div class="card-info">
                        <span class="card-nome">@item.Nome</span>
                        <span class="card-preco">R$ @item.Preco.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="categoria-secao">
        <h4 class="categoria-titulo">🏷️ Descontos</h4>
        <div class="cards-grid">
            @foreach (var desconto in cardapio.Descontos)
            {
                <div class="card-produto">
                    <div class="card-icone">💰</div>
                    <div class="card-info">
                        <span class="card-nome">@desconto.Descricao</span>
                        <span class="card-preco">@desconto.Percentual% de desconto</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="cardapio-rodape">
        <a href="/criar-pedido" class="btn-pedido">➕ Fazer Pedido</a>
    </div>
}

@code {
    private CardapioModel cardapio = new();
    private bool carregando = true;
    private string? erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cardapio = await CardapioService.ObterCardapioAsync();
        }
        catch (Exception ex)
        {
            erro = $"Não foi possível carregar o cardápio. Verifique se a API está rodando. ({ex.Message})";
        }
        finally
        {
            carregando = false;
        }
    }
}